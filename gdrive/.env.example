# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Path to the service account JSON key file (Google Cloud Console > IAM >
# Service Accounts > sloy-import-script@sloy-data.iam.gserviceaccount.com >
# Keys > Add Key > Create new key > JSON).
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json

# The folder must be shared with the service account's email address
# (sloy-import-script@sloy-data.iam.gserviceaccount.com) for this to work.
GDRIVE_FOLDER_ID=1c61JW7Em63X0cZmcSjITEceu9UiP2rD6

# Optional: overrides the default target folder used by
# export_product_translations_snapshot.py.
# GDRIVE_TRANSLATIONS_FOLDER_ID=1AOyI9fKLObpb4LTUp-4wa5RtdO_6dg7b

# export_product_translations_snapshot.py auths as your own Google user
# (OAuth), not the service account above — a service account has 0 bytes
# of Drive storage, so it can't create files. Path to the OAuth "Desktop
# app" client JSON downloaded from Cloud Console > APIs & Services >
# Credentials. See the script's docstring for the one-time setup steps.
# GOOGLE_OAUTH_CLIENT_FILE=./client_secret.json

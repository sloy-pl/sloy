# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Site root (no trailing slash)
WC_URL=Store domain

# WooCommerce REST API (WooCommerce → Settings → Advanced → REST API → Add key,
# permissions: Read/Write). Used to create products + categories.
WC_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WordPress Application Password (Users → Profile → Application Passwords).
# Used only to upload images to the media library. Keep the spaces or remove
# them — both work. WP_USER is your wp-admin login name.
WP_USER=your_admin_login
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

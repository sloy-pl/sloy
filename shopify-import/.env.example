# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Store domain, e.g. sloy-pl.myshopify.com (no https://, no trailing slash)
SHOPIFY_STORE=your-store.myshopify.com

# Client ID / Secret from a Dev Dashboard app (dev dashboard -> your app ->
# Settings). The app and the store must belong to the same Shopify
# organization — the script exchanges these for an Admin API access token
# via the client_credentials grant. Scopes (write_products, read_products)
# are configured on the app itself in the Dev Dashboard.
# https://shopify.dev/docs/apps/build/dev-dashboard/get-api-access-tokens
SHOPIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_CLIENT_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional, defaults to 2024-10
SHOPIFY_API_VERSION=2024-10

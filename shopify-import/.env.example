# Copy to .env and fill in. .env is gitignored — never commit real tokens.

# Store domain, e.g. sloy-pl.myshopify.com (no https://, no trailing slash)
SHOPIFY_STORE=your-store.myshopify.com

# Admin API access token from a custom app (Shopify admin -> Settings ->
# Apps and sales channels -> Develop apps -> create app -> Admin API scopes:
# write_products, read_products -> install -> reveal token).
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional, defaults to 2024-10
SHOPIFY_API_VERSION=2024-10

{% doc %}
  @prompt
    Wygeneruj dwa kwadratowe bloki, które będą miały jednolity kolor i na których będę mógł umieścić tekst, Zmniejsz je i dodaj na nich buttony, Niech okna będą szerokie zgodnie z szerokością innych elementów strony, ale niższe, nie tak duże jak teraz., Wyrównaj nagłówek i treści w oknach do lewej strony
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-tiles-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-text-tiles-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.gap }}px;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-text-tile-{{ ai_gen_id }} {
    min-height: {{ block.settings.tile_height }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: {{ block.settings.padding }}px;
    text-align: left;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-text-tile-{{ ai_gen_id }}--1 {
    background-color: {{ block.settings.tile_1_bg_color }};
  }

  .ai-text-tile-{{ ai_gen_id }}--2 {
    background-color: {{ block.settings.tile_2_bg_color }};
  }

  .ai-text-tile-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-text-tile-text-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.button_spacing }}px;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  .ai-text-tile-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    margin: 1px;
  }

  .ai-text-tile-button-{{ ai_gen_id }}:hover {
  background-color: {{ block.settings.button_hover_bg_color }};
  color: {{ block.settings.button_text_color }};
  margin: 0;
  border: 1px solid white;
}

  @media screen and (max-width: 749px) {
    .ai-text-tiles-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap | times: 0.75 }}px;
      padding: 0 {{ block.settings.horizontal_padding | times: 0.5 }}px;
    }

    .ai-text-tile-{{ ai_gen_id }} {
      min-height: {{ block.settings.tile_height | times: 0.8 }}px;
    }

    .ai-text-tile-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.85 }}px;
    }

    .ai-text-tile-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-text-tile-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<ai-text-tiles-{{ ai_gen_id }} class="ai-text-tiles-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-tiles-container-{{ ai_gen_id }}">
    <div class="ai-text-tile-{{ ai_gen_id }} ai-text-tile-{{ ai_gen_id }}--1">
      {% if block.settings.tile_1_heading != blank %}
        <h3 class="ai-text-tile-heading-{{ ai_gen_id }}">{{ block.settings.tile_1_heading }}</h3>
      {% endif %}
      {% if block.settings.tile_1_text != blank %}
        <div class="ai-text-tile-text-{{ ai_gen_id }}">{{ block.settings.tile_1_text }}</div>
      {% endif %}
      {% if block.settings.tile_1_button_text != blank %}
        <a href="{{ block.settings.tile_1_button_link }}" class="ai-text-tile-button-{{ ai_gen_id }}">
          {{ block.settings.tile_1_button_text }}
        </a>
      {% endif %}
    </div>

    <div class="ai-text-tile-{{ ai_gen_id }} ai-text-tile-{{ ai_gen_id }}--2">
      {% if block.settings.tile_2_heading != blank %}
        <h3 class="ai-text-tile-heading-{{ ai_gen_id }}">{{ block.settings.tile_2_heading }}</h3>
      {% endif %}
      {% if block.settings.tile_2_text != blank %}
        <div class="ai-text-tile-text-{{ ai_gen_id }}">{{ block.settings.tile_2_text }}</div>
      {% endif %}
      {% if block.settings.tile_2_button_text != blank %}
        <a href="{{ block.settings.tile_2_button_link }}" class="ai-text-tile-button-{{ ai_gen_id }}">
          {{ block.settings.tile_2_button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</ai-text-tiles-{{ ai_gen_id }}>

<script>
  (function() {
    class AiTextTiles{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('ai-text-tiles-{{ ai_gen_id }}', AiTextTiles{{ ai_gen_id }});
  })();
</script>


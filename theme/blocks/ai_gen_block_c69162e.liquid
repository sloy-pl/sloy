{% doc %}
  @prompt
    I want to generate tabs with the category names. After clicking a tab a collapsible contant should appear.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-tabs-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .ai-faq-tabs__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.heading_alignment }};
    margin: 0 0 32px;
  }

  .ai-faq-tabs__tab-list-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
    border-bottom: 2px solid {{ block.settings.tab_border_color }};
  }

  .ai-faq-tabs__tab-{{ ai_gen_id }} {
    padding: 12px 24px;
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    font-family: {{ block.settings.tab_font.family }}, {{ block.settings.tab_font.fallback_families }};
    font-weight: {{ block.settings.tab_font.weight }};
    font-size: {{ block.settings.tab_font_size }}px;
    color: {{ block.settings.tab_text_color }};
    white-space: nowrap;
    transition: all 0.3s ease;
    margin-bottom: -2px;
  }

  .ai-faq-tabs__tab-{{ ai_gen_id }}:hover {
    color: {{ block.settings.tab_active_color }};
  }

  .ai-faq-tabs__tab-{{ ai_gen_id }}.active {
    color: {{ block.settings.tab_active_color }};
    border-bottom-color: {{ block.settings.tab_active_color }};
  }

  .ai-faq-tabs__panel-{{ ai_gen_id }} {
    display: none;
  }

  .ai-faq-tabs__panel-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-faq-tabs__item-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.item_border_color }};
  }

  .ai-faq-tabs__item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-faq-tabs__question-{{ ai_gen_id }} {
    width: 100%;
    padding: 20px 48px 20px 0;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    font-family: {{ block.settings.question_font.family }}, {{ block.settings.question_font.fallback_families }};
    font-weight: {{ block.settings.question_font.weight }};
    font-size: {{ block.settings.question_font_size }}px;
    color: {{ block.settings.question_color }};
    position: relative;
    transition: color 0.3s ease;
  }

  .ai-faq-tabs__question-{{ ai_gen_id }}:hover {
    color: {{ block.settings.question_hover_color }};
  }

  .ai-faq-tabs__question-icon-{{ ai_gen_id }} {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 24px;
    height: 24px;
    transition: transform 0.3s ease;
  }

  .ai-faq-tabs__question-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
  }

  .ai-faq-tabs__question-{{ ai_gen_id }}[aria-expanded="true"] .ai-faq-tabs__question-icon-{{ ai_gen_id }} {
    transform: translateY(-50%) rotate(180deg);
  }

  .ai-faq-tabs__answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-faq-tabs__answer-content-{{ ai_gen_id }} {
    padding: 0 0 20px 0;
    font-family: {{ block.settings.answer_font.family }}, {{ block.settings.answer_font.fallback_families }};
    font-weight: {{ block.settings.answer_font.weight }};
    font-size: {{ block.settings.answer_font_size }}px;
    color: {{ block.settings.answer_color }};
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-tabs-{{ ai_gen_id }} {
      padding: 32px 16px;
    }

    .ai-faq-tabs__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
      margin-bottom: 24px;
    }

    .ai-faq-tabs__tab-{{ ai_gen_id }} {
      padding: 10px 16px;
      font-size: calc({{ block.settings.tab_font_size }}px * 0.9);
    }

    .ai-faq-tabs__question-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.question_font_size }}px * 0.9);
    }

    .ai-faq-tabs__answer-content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.answer_font_size }}px * 0.9);
    }
  }
{% endstyle %}

<faq-tabs-{{ ai_gen_id }} class="ai-faq-tabs-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-faq-tabs__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-faq-tabs__tab-list-{{ ai_gen_id }}" role="tablist">
    {% for i in (1..5) %}
      {% assign category_key = 'category_' | append: i | append: '_name' %}
      {% assign category_name = block.settings[category_key] %}
      
      {% if category_name != blank %}
        <button
          class="ai-faq-tabs__tab-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
          role="tab"
          aria-selected="{% if i == 1 %}true{% else %}false{% endif %}"
          aria-controls="ai-faq-panel-{{ ai_gen_id }}-{{ i }}"
          id="ai-faq-tab-{{ ai_gen_id }}-{{ i }}"
          data-tab="{{ i }}"
        >
          {{ category_name }}
        </button>
      {% endif %}
    {% endfor %}
  </div>

  {% for i in (1..5) %}
    {% assign category_key = 'category_' | append: i | append: '_name' %}
    {% assign category_name = block.settings[category_key] %}
    
    {% if category_name != blank %}
      <div
        class="ai-faq-tabs__panel-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
        role="tabpanel"
        id="ai-faq-panel-{{ ai_gen_id }}-{{ i }}"
        aria-labelledby="ai-faq-tab-{{ ai_gen_id }}-{{ i }}"
      >
        {% for j in (1..10) %}
          {% assign question_key = 'category_' | append: i | append: '_q' | append: j %}
          {% assign answer_key = 'category_' | append: i | append: '_a' | append: j %}
          {% assign question = block.settings[question_key] %}
          {% assign answer = block.settings[answer_key] %}
          
          {% if question != blank and answer != blank %}
            <div class="ai-faq-tabs__item-{{ ai_gen_id }}">
              <button
                class="ai-faq-tabs__question-{{ ai_gen_id }}"
                aria-expanded="false"
                aria-controls="ai-faq-answer-{{ ai_gen_id }}-{{ i }}-{{ j }}"
              >
                {{ question }}
                <span class="ai-faq-tabs__question-icon-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </span>
              </button>
              <div
                class="ai-faq-tabs__answer-{{ ai_gen_id }}"
                id="ai-faq-answer-{{ ai_gen_id }}-{{ i }}-{{ j }}"
              >
                <div class="ai-faq-tabs__answer-content-{{ ai_gen_id }}">
                  {{ answer }}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  {% endfor %}
</faq-tabs-{{ ai_gen_id }}>

<script>
  (function() {
    class FaqTabs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabs = this.querySelectorAll('.ai-faq-tabs__tab-{{ ai_gen_id }}');
        this.panels = this.querySelectorAll('.ai-faq-tabs__panel-{{ ai_gen_id }}');
        this.questions = this.querySelectorAll('.ai-faq-tabs__question-{{ ai_gen_id }}');
        
        this.setupTabs();
        this.setupAccordions();
      }

      setupTabs() {
        this.tabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            const tabNumber = tab.getAttribute('data-tab');
            
            this.tabs.forEach((t) => {
              t.classList.remove('active');
              t.setAttribute('aria-selected', 'false');
            });
            
            this.panels.forEach((p) => {
              p.classList.remove('active');
            });
            
            tab.classList.add('active');
            tab.setAttribute('aria-selected', 'true');
            
            const activePanel = this.querySelector('#ai-faq-panel-{{ ai_gen_id }}-' + tabNumber);
            if (activePanel) {
              activePanel.classList.add('active');
            }
          });
        });
      }

      setupAccordions() {
        this.questions.forEach((question) => {
          question.addEventListener('click', () => {
            const answerId = question.getAttribute('aria-controls');
            const answer = this.querySelector('#' + answerId);
            const isExpanded = question.getAttribute('aria-expanded') === 'true';
            
            if (isExpanded) {
              question.setAttribute('aria-expanded', 'false');
              answer.style.maxHeight = '0';
            } else {
              question.setAttribute('aria-expanded', 'true');
              answer.style.maxHeight = answer.scrollHeight + 'px';
            }
          });
        });
      }
    }

    customElements.define('faq-tabs-{{ ai_gen_id }}', FaqTabs{{ ai_gen_id }});
  })();
</script>


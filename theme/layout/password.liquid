      <!-- Katalog – tylko raz, bez duplikatu -->
      <div class="catalog-embed">
        <div>
          <iframe src="https://online.fliphtml5.com/SLOYPL/SLOY-2025/"></iframe>
        </div>
      </div>
    </main>


{%- liquid
	assign heading_block = section.blocks | where: "type", "heading" | first
	assign has_heading = true
	if heading_block == blank or heading_block.settings.title == blank
		assign has_heading = false
	endif
-%}

<section
	class="
		Vtls-{{ section.id | handle }}
		{% if section.settings.section_background_style == 'color' %}Vtls-{{ section.id | handle }}--hasBackground{% endif %}
		{% if section.settings.section_background_style == 'gradient' %}Vtls-{{ section.id | handle }}--hasGradient{% endif %}
		{% if section.settings.section_background_style == 'gradient' and section.settings.section_background_animation %}Vtls-{{ section.id | handle }}--hasAnimation{% endif %}
	"
	{% if has_heading %}
		aria-labelledby="VtlsFaqHeading-{{ section.id }}"
	{% else %}
		aria-label="Frequently Asked Questions"
	{% endif %}
>
	<vtls-faq>
		<div class="VtlsContainer">
			{% for block in section.blocks %}
				{% case block.type %}
					{% when "heading" %}
						<h2 class="VtlsHeading" id="VtlsFaqHeading-{{ section.id }}" {{ block.shopify_attributes }}>
							{{ block.settings.title }}
						</h2>
					{% when "question" %}
						<div
							class="VtlsItem {% if section.settings.showLineSeparator %} VtlsItem--hasDivider{% endif %}"
							{{ block.shopify_attributes }}
						>
							<input
								style="display:none!important;"
								type="checkbox"
								id="toggle-{{ section.id | handle }}-{{forloop.index}}"
								class="VtlsItem__Toggle"
								{% if request.design_mode == true %}
									checked
								{% endif %}
							>
							<label
								for="toggle-{{ section.id | handle }}-{{forloop.index}}"
								class="VtlsItem__Summary"
								id="VtlsFaqSummary-{{ section.id }}-{{ forloop.index }}"
								role="button"
								tabindex="0"
								aria-controls="VtlsFaqPanel-{{ section.id }}-{{ forloop.index }}"
								aria-expanded="{% if request.design_mode %}true{% else %}false{% endif %}"
							>
								{{ block.settings.question }}
							</label>
							<div
								class="VtlsItem__Answer"
								id="VtlsFaqPanel-{{ section.id }}-{{ forloop.index }}"
								aria-labelledby="VtlsFaqSummary-{{ section.id }}-{{ forloop.index }}"
								aria-hidden="{% if request.design_mode %}false{% else %}true{% endif %}"
							>
								{{ block.settings.answer }}
								{% if block.settings.buttonCheckbox %}
									{% capture btn_style %}
									{%- case block.settings.buttonStyle -%}
										{%- when 'filled' -%}
											color: {{ block.settings.buttonTextColor }};
											background-color: {{ block.settings.buttonColor }};
											border-radius: {{ block.settings.buttonCornerRadius }}px;
										{%- when 'outline' -%}
											color: {{ block.settings.buttonColor }};
											border: var(--vtl-border-width-1) solid {{ block.settings.buttonColor }};
											border-radius: {{ block.settings.buttonCornerRadius }}px;
									{%- endcase -%}
								{% endcapture %}

									<div class="VtlsButton">
										<a
											href="{{ block.settings.buttonLink }}"
											class="VtlsButton__Link VtlsButton__Link--{{ block.settings.buttonSize }}"
											style="{{ btn_style }}"
											target="_blank"
											rel="noopener noreferrer"
										>
											{{- block.settings.buttonLabel -}}
										</a>
									</div>
								{% endif %}
							</div>
						</div>
				{% endcase %}
			{% endfor %}
		</div>
	</vtls-faq>
</section>

